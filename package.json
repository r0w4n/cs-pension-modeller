{
  "name": "cs-pension-modeller",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "check:full": "npm run check && npm run test:e2e && npm run test:a11y && npm run test:smoke:prod && npm run audit",
    "audit": "npm audit --audit-level=moderate",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint:eslint && npm run lint:knip",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:knip": "knip --dependencies --files",
    "lint:hook": "npm run lint",
    "preview": "vite preview",
    "prepublishOnly": "sh .githooks/pre-publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "test:e2e": "playwright test e2e/app.spec.ts",
    "test:smoke:prod": "npm run build && playwright test e2e/production-smoke.spec.ts --config playwright.prod.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.1.4",
    "vitest": "^4.1.5"
  }
}
