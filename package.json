{
  "name": "cs-pension-modeller",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run lint && npm run audit && npm run test:coverage && npm run build",
    "audit": "npm audit --audit-level=moderate",
    "lint": "npm run lint:eslint && npm run lint:knip",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:knip": "knip --dependencies --files",
    "lint:hook": "npm run lint",
    "preview": "vite preview",
    "prepublishOnly": "sh .githooks/pre-publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.14.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.1.4",
    "vitest": "^4.1.5"
  }
}
